# ==============================================================================
# Glass Loans - AI Underwriting Tool
# Environment Variables Template
# ==============================================================================

# Base URL (required for email verification links)
NEXT_PUBLIC_BASE_URL=https://glassloans.io

# ==============================================================================
# Email (SendGrid) - Already Configured
# ==============================================================================
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=info@glassloans.io
CONTACT_EMAIL=info@glassloans.io

# Optional: SendGrid dynamic template ID for confirmation emails
# SENDGRID_TEMPLATE_ID=

# ==============================================================================
# Database - PostgreSQL (via Prisma)
# ==============================================================================
# Local: Run `docker-compose up -d` to start Postgres, then use:
DATABASE_URL=postgresql://glass_loans:local_dev_password@localhost:5432/glass_loans_dev
# Production: Automatically set by Fly.io when Postgres is attached

# ==============================================================================
# Email Validation (AbstractAPI) - OPTIONAL
# ==============================================================================
# OPTIONAL: Enhanced disposable email detection (knows hundreds of domains)
# If not set, falls back to basic validation with 10 common disposable domains
# Note: Email normalization (preventing user+1@gmail.com tricks) is handled
# automatically without this API via src/lib/email/normalization.ts
# Note: We ONLY use disposable detection - risk/quality scoring disabled (too aggressive)
ABSTRACT_API_KEY=your_abstractapi_key

# ==============================================================================
# AI (OpenRouter - Grok)
# ==============================================================================
OPENROUTER_API_KEY=your_openrouter_api_key

# ==============================================================================
# Stripe (Payment Processing) - Underwrite Pro Subscriptions
# ==============================================================================
# Test Mode (for development and testing)
STRIPE_SECRET_KEY=sk_test_your_test_secret_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_test_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key

# Price IDs (Test Mode - create these in Stripe dashboard)
# Note: Using NEXT_PUBLIC_ prefix so they're available on client side (price IDs are not secrets)
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY_REGULAR=price_test_monthly_regular_id
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL_REGULAR=price_test_annual_regular_id
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY_PROMO=price_test_monthly_promo_id
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL_PROMO=price_test_annual_promo_id

# Note: For production, replace with sk_live_..., pk_live_..., and live price IDs
# See IMPLEMENTATION_PLAN_STRIPE.md for setup instructions

# ==============================================================================
# Security (reCAPTCHA v3) - Phase 7
# ==============================================================================
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# ==============================================================================
# JWT (for secure sessions) - Phase 7
# ==============================================================================
JWT_SECRET=your_random_jwt_secret_min_32_chars

# ==============================================================================
# Google Places API (for address autocomplete)
# ==============================================================================
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ==============================================================================
# Mapbox (for comp selection maps)
# ==============================================================================
# Used to display comparable properties on an interactive map in Step 6
#
# Setup Instructions:
# 1. Create account at: https://account.mapbox.com/
# 2. Go to: https://account.mapbox.com/access-tokens/
# 3. Click "Create a token"
# 4. Token Settings:
#    - Name: "Glass Loans Production" (or your choice)
#    - Scopes Required:
#      ✓ styles:tiles (Maps SDK - for displaying the map)
#      ✓ styles:read (Style resources - for mapbox://styles/mapbox/streets-v12)
#    - Optional URL Restrictions (recommended for production):
#      https://glassloans.io/*
#      http://localhost:3000/* (for local development)
# 5. Copy the public token (starts with "pk.")
# 6. Paste below
#
# Note: This is a PUBLIC token (safe to expose in client-side code)
NEXT_PUBLIC_MAPBOX_API_KEY=your_mapbox_api_key

# ==============================================================================
# Realie.ai API (Real Estate Data - Property Comps)
# ==============================================================================
# Premium Comparables Search API key
# Get your API key from: https://app.realie.ai/settings/api
REALIE_API_KEY=your_realie_api_key

# ==============================================================================
# RentCast API (Real Estate Data - Property Comps)
# ==============================================================================
# Property Search API key
# Get your API key from: https://developers.rentcast.io
RENTCAST_API_KEY=your_rentcast_api_key

# ==============================================================================
# Comps Provider Configuration (Optional)
# ==============================================================================
# Choose which data provider to use for comparable properties
# Options: "rentcast", "realie", "batchdata"
# Default: "rentcast"
# If primary provider fails, it will automatically fall back to other available providers
COMPS_PROVIDER=rentcast

# ==============================================================================
# Google Sheets (Legacy - keeping for existing contact form)
# ==============================================================================
GOOGLE_CLIENT_EMAIL=your_google_service_account_email
GOOGLE_PRIVATE_KEY=your_google_private_key
GOOGLE_SHEET_ID=your_google_sheet_id
